# Hydrogen / Oxygen environment variables.
# Keep real values in .env locally and Oxygen environment settings in production.
SESSION_SECRET=replace_with_a_long_random_string
PUBLIC_STORE_DOMAIN=pf2r62-r8.myshopify.com
PUBLIC_CHECKOUT_DOMAIN=pf2r62-r8.myshopify.com
PUBLIC_STOREFRONT_API_TOKEN=your_storefront_access_token
PUBLIC_STOREFRONT_API_VERSION=2026-01

# Club inquiry delivery.
# Email delivery uses Resend: https://resend.com
RESEND_API_KEY=your_resend_api_key
CLUB_INQUIRY_EMAIL_TO=quotes@example.com
CLUB_INQUIRY_EMAIL_FROM=BladeCraft <quotes@example.com>

# Optional Google Sheets backup via an Apps Script Web App URL.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your_deployment_id/exec
